<Main>
  <main class="">
    <section class="bg-slate-600 pt-10 mt-12 relative">
      <img class="w-40 h-40 mx-auto mt-5 rounded-full shadow-xl"src="me.jpg" alt="Steven's Face"/>
      <h1 class="px-5 text-4xl text-gray-50 text-center">Hi my name is Steven.</h1>
      <h2 class="px-5 text-2xl text-center">Im a Engineer by trade and a Maker by passion.</h2>
      <h3 class="pt-5 text-center pb-40 px-5 font-bold text-xl"><span class="transform scale-x-[-1]">🎉</span>Welcome to my little corner of the internet.🎉</h3>        
